---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/public-sans';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../lib/content';
import { t, LOCALES, type Locale } from '../i18n/ui';
import { stripLocale, localize } from '../i18n/utils';

interface Props {
  lang: Locale;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const tt = t[lang];
const desc = description ?? tt.meta.description;
const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${tt.meta.tagline}`;

const agnostic = stripLocale(Astro.url.pathname);
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternates = LOCALES.map((l) => ({
  hreflang: l,
  href: new URL(localize(agnostic, l), Astro.site).href,
}));
const xDefault = new URL(localize(agnostic, 'en'), Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: Astro.site?.href,
  logo: new URL('/logo_maker_commons_fill.png', Astro.site).href,
  description: tt.meta.description,
  sameAs: [SITE.org],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <meta name="theme-color" content="#f1ede3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f1b1f" media="(prefers-color-scheme: dark)" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MakerCommons" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="MakerCommons — small tools for real problems, free and open source" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/logo_maker_commons_fill.png" />
    <link rel="apple-touch-icon" href="/logo_maker_commons_fill.png" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Runs before paint: flags JS (gates scroll-reveal) and applies the
         saved theme so there's no light/dark flash on load. -->
    <script is:inline>
      document.documentElement.classList.add('js');
      try {
        var th = localStorage.getItem('theme');
        if (th === 'dark' || th === 'light') document.documentElement.classList.add(th);
      } catch (e) {}
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-ink focus:px-4 focus:py-2 focus:text-paper"
      >{lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}</a
    >
    <SiteNav lang={lang} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter lang={lang} />

    <script>
      // Progressive scroll reveal — no-op under reduced motion (CSS guards it).
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
