---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../ProjectCard.astro';
import MakerCard from '../MakerCard.astro';
import { SITE } from '../../lib/content';
import { t, type Locale } from '../../i18n/ui';
import { localize } from '../../i18n/utils';
import { getProjects, getMakers } from '../../lib/github';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tt = t[lang];

const projects = await getProjects();
const makers = await getMakers();

const featured = projects.slice(0, 6);
const featuredMakers = makers.slice(0, 8);
---

<Base lang={lang}>
  <!-- ============================ HERO ============================ -->
  <section class="pegboard-strong relative overflow-hidden border-b-2 border-ink">
    <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-full bg-gradient-to-b from-paper/40 via-paper/70 to-paper"></div>
    <div class="mx-auto max-w-6xl px-5 pb-20 pt-20 sm:pt-28">
      <p class="tag inline-flex items-center gap-2 rounded-full border-2 border-ink bg-paper px-3 py-1">
        <span class="h-2 w-2 rounded-full bg-commons"></span>
        {tt.hero.eyebrow}
      </p>

      <h1 class="mt-7 max-w-4xl font-display text-5xl font-extrabold leading-[0.98] tracking-tight sm:text-7xl">
        {tt.hero.h1a}<br />{tt.hero.h1b}<br />
        {tt.hero.h1pre}<span class="riso" data-text={tt.hero.h1riso}>{tt.hero.h1riso}</span>{tt.hero.h1post}
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft sm:text-xl">
        {tt.hero.sub}
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href={SITE.newIssue} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-ink px-6 py-3 font-semibold text-paper transition-transform hover:-translate-y-0.5">
          {tt.hero.ctaBring}
        </a>
        <a href={SITE.manifesto} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-6 py-3 font-semibold text-ink transition-transform hover:-translate-y-0.5">
          {tt.hero.ctaManifesto}
        </a>
      </div>

      <dl class="mt-12 flex flex-wrap gap-x-8 gap-y-3 border-t-2 border-ink pt-5 font-mono text-sm">
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">{tt.hero.lblStatus}</dt>
          <dd class="font-medium">{tt.hero.status}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">{tt.hero.lblTools}</dt>
          <dd class="font-medium">{tt.hero.tools(projects.length)}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">{tt.hero.lblMakers}</dt>
          <dd class="font-medium">{tt.hero.makers(makers.length)}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">{tt.hero.lblLicense}</dt>
          <dd class="font-medium">{SITE.license}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ STORY ============================ -->
  <section class="border-b-2 border-ink">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-20 md:grid-cols-[0.8fr_1.2fr]">
      <div class="reveal">
        <p class="tag text-commons-deep">{tt.story.eyebrow}</p>
        <p class="mt-4 font-display text-2xl font-bold leading-tight sm:text-3xl">
          {tt.story.headingA}<br class="hidden sm:block" /> {tt.story.headingB}
        </p>
      </div>
      <div class="reveal space-y-5 text-lg leading-relaxed text-ink-soft">
        {tt.story.paragraphs.map((p) => <p>{p}</p>)}
        <p class="tag pt-2 text-ink">{tt.story.signoff}</p>
      </div>
    </div>
  </section>

  <!-- ========================= HOW IT WORKS ======================= -->
  <section id="how" class="border-b-2 border-ink bg-paper-2">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="max-w-2xl">
        <p class="tag text-commons-deep">{tt.how.eyebrow}</p>
        <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">{tt.how.title}</h2>
        <p class="mt-4 text-lg text-ink-soft">{tt.how.sub}</p>
      </header>

      <ol class="mt-12 grid gap-px overflow-hidden rounded-xl border-2 border-ink bg-ink sm:grid-cols-2 lg:grid-cols-5">
        {
          tt.how.steps.map((s) => (
            <li class="reveal flex flex-col bg-paper p-6">
              <span class="font-mono text-sm font-medium text-commons-deep">{s.n}</span>
              <h3 class="mt-3 font-display text-lg font-bold leading-tight">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ========================== PROJECTS ========================== -->
  <section id="projects" class="pegboard border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="tag text-commons-deep">{tt.projects.eyebrow}</p>
          <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">{tt.projects.title}</h2>
          <p class="mt-4 text-lg text-ink-soft">{tt.projects.sub}</p>
        </div>
        {
          projects.length > 6 && (
            <a href={localize('/projects', lang)}
              class="rounded-lg border-2 border-ink bg-paper px-4 py-2 text-sm font-semibold transition-transform hover:-translate-y-0.5">
              {tt.projects.all(projects.length)}
            </a>
          )
        }
      </header>

      {
        featured.length > 0 ? (
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((p) => (
              <div class="reveal">
                <ProjectCard project={p} lang={lang} />
              </div>
            ))}
          </div>
        ) : (
          <div class="reveal mt-12 grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-16 text-center">
            <p class="font-display text-2xl font-bold">{tt.projects.emptyTitle}</p>
            <p class="mt-3 max-w-md text-ink-soft">{tt.projects.emptyBody}</p>
            <a href={SITE.newIssue} target="_blank" rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-5 py-2.5 font-semibold text-paper transition-transform hover:-translate-y-0.5">
              {tt.projects.emptyCta}
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ========================= PRINCIPLES ========================= -->
  <section class="border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="max-w-2xl">
        <p class="tag text-commons-deep">{tt.principles.eyebrow}</p>
        <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">{tt.principles.title}</h2>
      </header>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {
          tt.principles.items.map((p) => (
            <div class="reveal rounded-xl border-2 border-ink bg-paper p-7">
              <p class="tag text-ink-soft">{p.tag}</p>
              <h3 class="mt-2 font-display text-2xl font-bold leading-tight">{p.title}</h3>
              <p class="mt-3 leading-relaxed text-ink-soft">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================== MAKERS =========================== -->
  <section id="makers" class="border-b-2 border-ink bg-paper-2">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="tag text-commons-deep">{tt.makers.eyebrow}</p>
          <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">{tt.makers.title}</h2>
          <p class="mt-4 text-lg text-ink-soft">{tt.makers.sub}</p>
        </div>
        {
          makers.length > 8 && (
            <a href={localize('/team', lang)}
              class="rounded-lg border-2 border-ink bg-paper px-4 py-2 text-sm font-semibold transition-transform hover:-translate-y-0.5">
              {tt.makers.all(makers.length)}
            </a>
          )
        }
      </header>

      {
        featuredMakers.length > 0 ? (
          <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {featuredMakers.map((m) => (
              <div class="reveal">
                <MakerCard maker={m} />
              </div>
            ))}
          </div>
        ) : (
          <div class="reveal mt-12 rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-14 text-center">
            <p class="font-display text-2xl font-bold">{tt.makers.emptyTitle}</p>
            <p class="mx-auto mt-3 max-w-md text-ink-soft">{tt.makers.emptyBody}</p>
            <a href={SITE.contributing} target="_blank" rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-5 py-2.5 font-semibold transition-transform hover:-translate-y-0.5">
              {tt.makers.emptyCta}
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ============================ CTA ============================= -->
  <section class="pegboard-strong relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-paper/70"></div>
    <div class="mx-auto max-w-6xl px-5 py-24 text-center">
      <h2 class="mx-auto max-w-3xl font-display text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
        {tt.cta.titleA}<br class="hidden sm:block" /> {tt.cta.titleB}
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-soft">{tt.cta.sub}</p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <a href={SITE.newIssue} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-7 py-3.5 font-semibold text-paper transition-transform hover:-translate-y-0.5">
          {tt.cta.ctaBring}
        </a>
        <a href={SITE.org} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-7 py-3.5 font-semibold text-ink transition-transform hover:-translate-y-0.5">
          {tt.cta.ctaExplore}
        </a>
      </div>
    </div>
  </section>
</Base>
