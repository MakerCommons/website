---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../ProjectCard.astro';
import { SITE } from '../../lib/content';
import { t, type Locale } from '../../i18n/ui';
import { getProjects } from '../../lib/github';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tp = t[lang].projects;
const projects = await getProjects();
---

<Base lang={lang} title={t[lang].meta.projectsTitle}>
  <section class="pegboard border-b-2 border-ink">
    <div class="container-page pb-16 pt-16 sm:pt-20">
      <p class="tag text-commons-deep">{tp.eyebrow}</p>
      <h1 class="mt-3 font-display text-5xl font-extrabold tracking-tight sm:text-6xl">{tp.pageTitle}</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">{tp.pageSub}</p>
    </div>
  </section>

  <section>
    <div class="container-page py-16">
      {
        projects.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
            {projects.map((p) => (
              <div class="reveal">
                <ProjectCard project={p} lang={lang} />
              </div>
            ))}
          </div>
        ) : (
          <div class="grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-20 text-center">
            <p class="font-display text-2xl font-bold">{tp.pageEmptyTitle}</p>
            <p class="mt-3 max-w-md text-ink-soft">{tp.pageEmptyBody}</p>
            <a href={SITE.newIssue} target="_blank" rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-5 py-2.5 font-semibold text-paper transition-transform hover:-translate-y-0.5">
              {tp.pageEmptyCta}
            </a>
          </div>
        )
      }
    </div>
  </section>
</Base>
