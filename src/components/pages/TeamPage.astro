---
import Base from '../../layouts/Base.astro';
import MakerCard from '../MakerCard.astro';
import { SITE } from '../../lib/content';
import { t, type Locale } from '../../i18n/ui';
import { getMakers } from '../../lib/github';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tm = t[lang].makers;
const makers = await getMakers();
---

<Base lang={lang} title={t[lang].meta.teamTitle}>
  <section class="pegboard border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 sm:pt-20">
      <p class="tag text-commons-deep">{tm.eyebrow}</p>
      <h1 class="mt-3 font-display text-5xl font-extrabold tracking-tight sm:text-6xl">{tm.pageTitle}</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">{tm.pageSub}</p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-5 py-16">
      {
        makers.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {makers.map((m) => (
              <div class="reveal">
                <MakerCard maker={m} />
              </div>
            ))}
          </div>
        ) : (
          <div class="grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-20 text-center">
            <p class="font-display text-2xl font-bold">{tm.pageEmptyTitle}</p>
            <p class="mt-3 max-w-md text-ink-soft">{tm.pageEmptyBody}</p>
            <a href={SITE.contributing} target="_blank" rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-5 py-2.5 font-semibold transition-transform hover:-translate-y-0.5">
              {tm.pageEmptyCta}
            </a>
          </div>
        )
      }
    </div>
  </section>
</Base>
