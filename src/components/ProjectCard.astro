---
import type { Project } from '../lib/github';

interface Props {
  project: Project;
}
const { project } = Astro.props;

// A small, stable palette of language dots — falls back to marigold.
const LANG_COLORS: Record<string, string> = {
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Rust: '#dea584',
  Python: '#3572A5',
  Go: '#00ADD8',
  Astro: '#ff5d01',
  Svelte: '#ff3e00',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Shell: '#89e051',
};
const dot = project.language ? LANG_COLORS[project.language] ?? '#e0a020' : null;
---

<article
  class="peg-hook relative flex flex-col rounded-xl border-2 border-ink bg-paper p-6 transition-transform duration-200 hover:-translate-y-1"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-display text-xl font-bold leading-tight">
      <a href={project.url} target="_blank" rel="noopener" class="hover:text-commons-deep">
        {project.name}
      </a>
    </h3>
    {
      project.stars > 0 && (
        <span class="tag inline-flex items-center gap-1 rounded-full border border-line px-2 py-0.5 text-ink-soft">
          ★ {project.stars}
        </span>
      )
    }
  </div>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft">
    {project.description ?? 'No description yet — open the repo to see what it does.'}
  </p>

  {
    project.topics.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {project.topics.slice(0, 4).map((t) => (
          <li class="tag rounded-full bg-paper-2 px-2 py-0.5 text-ink-soft">{t}</li>
        ))}
      </ul>
    )
  }

  <div class="mt-5 flex items-center justify-between border-t border-line pt-4">
    <span class="flex items-center gap-2 text-xs font-medium text-ink-soft">
      {dot && <span class="h-2.5 w-2.5 rounded-full" style={`background:${dot}`} />}
      {project.language ?? 'Repository'}
    </span>
    <div class="flex items-center gap-3">
      {
        project.homepage && (
          <a
            href={project.homepage}
            target="_blank"
            rel="noopener"
            class="text-xs font-semibold text-commons-deep underline-offset-4 hover:underline"
          >
            Try it →
          </a>
        )
      }
      <a
        href={project.url}
        target="_blank"
        rel="noopener"
        class="text-xs font-semibold text-ink underline-offset-4 hover:underline"
      >
        Code →
      </a>
    </div>
  </div>
</article>
