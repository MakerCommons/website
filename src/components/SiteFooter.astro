---
import { SITE } from '../lib/content';
import { t, type Locale } from '../i18n/ui';
import { localize } from '../i18n/utils';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const f = t[lang].footer;

const cols = [
  {
    head: f.collective,
    links: [
      { href: SITE.manifesto, label: f.manifesto, external: true },
      { href: SITE.contributing, label: f.contributing, external: true },
      { href: SITE.org, label: f.org, external: true },
    ],
  },
  {
    head: f.takePart,
    links: [
      { href: SITE.newIssue, label: f.bring, external: true },
      { href: SITE.newIssue, label: f.propose, external: true },
      { href: localize('/projects', lang), label: f.browse },
      { href: localize('/#support', lang), label: f.support },
    ],
  },
];
---

<footer class="border-t-2 border-ink bg-paper-2">
  <div class="container-page grid gap-10 py-14 sm:grid-cols-2 md:grid-cols-4">
    <div class="sm:col-span-2 md:col-span-2">
      <span class="font-display text-xl font-bold tracking-tight">
        Maker<span class="text-commons-deep">Commons</span>
      </span>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink-soft">
        {t[lang].meta.description}
      </p>
      <p class="tag mt-5 text-ink-soft">
        Est. {SITE.est} · {SITE.license} · {f.built}
      </p>
    </div>

    {
      cols.map((c) => (
        <nav aria-label={c.head}>
          <h2 class="tag mb-3 text-ink-soft/80">{c.head}</h2>
          <ul class="space-y-2">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  target={l.external ? '_blank' : undefined}
                  rel={l.external ? 'noopener' : undefined}
                  class="text-sm font-medium text-ink underline-offset-4 hover:text-commons-deep hover:underline"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-line">
    <div class="container-page flex flex-col gap-1 py-5 text-xs text-ink-soft sm:flex-row sm:items-center sm:justify-between">
      <span>© {SITE.est} MakerCommons · {f.rights}</span>
      <span class="font-mono">{f.motto}</span>
    </div>
  </div>
</footer>
