---
import { SITE } from '../lib/content';

const cols = [
  {
    head: 'The collective',
    links: [
      { href: SITE.manifesto, label: 'Manifesto', external: true },
      { href: SITE.contributing, label: 'Contributing', external: true },
      { href: SITE.org, label: 'GitHub org', external: true },
    ],
  },
  {
    head: 'Take part',
    links: [
      { href: SITE.newIssue, label: 'Bring a problem', external: true },
      { href: SITE.newIssue, label: 'Propose a tool', external: true },
      { href: '/projects', label: 'Browse projects' },
    ],
  },
];
---

<footer class="border-t-2 border-ink bg-paper-2">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 md:grid-cols-4">
    <div class="sm:col-span-2 md:col-span-2">
      <span class="font-display text-xl font-bold tracking-tight">
        Maker<span class="text-commons-deep">Commons</span>
      </span>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink-soft">
        {SITE.description}
      </p>
      <p class="tag mt-5 text-ink-soft">
        Est. {SITE.est} · {SITE.license} · built by the commons
      </p>
    </div>

    {
      cols.map((c) => (
        <nav aria-label={c.head}>
          <h2 class="tag mb-3 text-ink-soft/80">{c.head}</h2>
          <ul class="space-y-2">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  target={l.external ? '_blank' : undefined}
                  rel={l.external ? 'noopener' : undefined}
                  class="text-sm font-medium text-ink underline-offset-4 hover:text-commons-deep hover:underline"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-line">
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-5 py-5 text-xs text-ink-soft sm:flex-row sm:items-center sm:justify-between">
      <span>© {SITE.est} MakerCommons · Free & open under {SITE.license}.</span>
      <span class="font-mono">Point powerful tools at real problems. Give the results away.</span>
    </div>
  </div>
</footer>
