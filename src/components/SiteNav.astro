---
import { SITE } from '../lib/content';
import { t, LOCALES, LOCALE_LABEL, LOCALE_NAME, type Locale } from '../i18n/ui';
import { stripLocale, localize } from '../i18n/utils';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const nav = t[lang].nav;
const agnostic = stripLocale(Astro.url.pathname);

const links = [
  { href: localize('/#how', lang), label: nav.how },
  { href: localize('/projects', lang), label: nav.projects },
  { href: localize('/team', lang), label: nav.makers },
  { href: SITE.manifesto, label: nav.manifesto, external: true },
];
---

<header class="sticky top-0 z-40 border-b border-line/80 bg-paper/85 backdrop-blur-md">
  <nav class="container-page flex items-center justify-between gap-4 py-3">
    <a href={localize('/', lang)} class="group flex items-center gap-2.5" aria-label="MakerCommons home">
      <img
        src="/logo_maker_commons_fill.png"
        alt=""
        width="36"
        height="36"
        class="h-9 w-9 rounded-lg border-2 border-ink"
        aria-hidden="true"
      />
      <span class="font-display text-[1.15rem] font-bold leading-none tracking-tight">
        Maker<span class="text-commons-deep">Commons</span>
      </span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 md:flex">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener' : undefined}
                class="rounded-md px-3 py-2 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-2 hover:text-ink"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Language switcher -->
      <div class="flex items-center rounded-md border-2 border-ink" role="group" aria-label={nav.language}>
        {
          LOCALES.map((l, i) => (
            <a
              href={localize(agnostic, l)}
              hreflang={l}
              lang={l}
              aria-label={LOCALE_NAME[l]}
              aria-current={l === lang ? 'true' : undefined}
              class:list={[
                'px-2 py-1.5 text-xs font-mono font-medium transition-colors',
                i > 0 && 'border-l-2 border-ink',
                l === lang ? 'bg-ink text-paper' : 'text-ink-soft hover:bg-paper-2 hover:text-ink',
              ]}
            >
              {LOCALE_LABEL[l]}
            </a>
          ))
        }
      </div>

      <button
        id="theme-toggle"
        type="button"
        aria-label={nav.toggleTheme}
        title={nav.toggleTheme}
        class="grid h-9 w-9 place-items-center rounded-md border-2 border-ink bg-paper text-ink transition-transform hover:-translate-y-0.5"
      >
        <svg class="t-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
        </svg>
        <svg class="t-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" />
          <path d="M12 2v2.5M12 19.5V22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M2 12h2.5M19.5 12H22M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8" />
        </svg>
      </button>

      <a
        href={SITE.newIssue}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-md border-2 border-ink bg-ink px-3.5 py-2 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5 sm:inline-flex"
      >
        {nav.bring}
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var html = document.documentElement;
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function systemDark() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches;
    }
    function isDark() {
      if (html.classList.contains('dark')) return true;
      if (html.classList.contains('light')) return false;
      return systemDark();
    }
    function setThemeColorMeta(dark) {
      var m = document.querySelector('meta[name="theme-color"]:not([media])');
      if (!m) {
        m = document.createElement('meta');
        m.setAttribute('name', 'theme-color');
        document.head.appendChild(m);
      }
      m.setAttribute('content', dark ? '#0f1b1f' : '#f1ede3');
    }
    btn.addEventListener('click', function () {
      var next = isDark() ? 'light' : 'dark';
      html.classList.remove('dark', 'light');
      html.classList.add(next);
      try { localStorage.setItem('theme', next); } catch (e) {}
      setThemeColorMeta(next === 'dark');
    });
  })();
</script>
