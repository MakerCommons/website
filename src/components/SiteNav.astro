---
import { SITE } from '../lib/content';

const links = [
  { href: '/#how', label: 'How it works' },
  { href: '/projects', label: 'Projects' },
  { href: '/team', label: 'Makers' },
  { href: SITE.manifesto, label: 'Manifesto', external: true },
];
---

<header class="sticky top-0 z-40 border-b border-line/80 bg-paper/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3.5">
    <a href="/" class="group flex items-center gap-2.5" aria-label="MakerCommons home">
      <span
        class="grid h-8 w-8 place-items-center rounded-[7px] border-2 border-ink bg-commons text-paper"
        aria-hidden="true"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a4 4 0 0 0-5.6 5.6l-6.4 6.4a1.5 1.5 0 0 0 2.1 2.1l6.4-6.4a4 4 0 0 0 5.6-5.6l-2.5 2.5-2.1-2.1 2.5-2.5Z" />
        </svg>
      </span>
      <span class="font-display text-[1.15rem] font-bold leading-none tracking-tight">
        Maker<span class="text-commons-deep">Commons</span>
      </span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 md:flex">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener' : undefined}
                class="rounded-md px-3 py-2 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-2 hover:text-ink"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={SITE.newIssue}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 rounded-md border-2 border-ink bg-ink px-3.5 py-2 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5"
      >
        Bring a problem
      </a>
    </div>
  </nav>
</header>
