---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../lib/content';
import { getProjects } from '../lib/github';

const projects = await getProjects();
---

<Base title="Projects" description="Every free, open-source tool the MakerCommons collective has shipped.">
  <section class="pegboard border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 sm:pt-20">
      <p class="tag text-commons-deep">The board</p>
      <h1 class="mt-3 font-display text-5xl font-extrabold tracking-tight sm:text-6xl">
        Projects
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">
        Every tool the collective has hung on the pegboard. Free, open source under
        {SITE.license}, and built for a real problem someone actually had.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-5 py-16">
      {
        projects.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((p) => (
              <div class="reveal">
                <ProjectCard project={p} />
              </div>
            ))}
          </div>
        ) : (
          <div class="grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-20 text-center">
            <p class="font-display text-2xl font-bold">Nothing on the board yet.</p>
            <p class="mt-3 max-w-md text-ink-soft">
              The commons is brand new. The first tool starts with a real problem —
              bring one and we’ll build it in the open.
            </p>
            <a
              href={SITE.newIssue}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-5 py-2.5 font-semibold text-paper transition-transform hover:-translate-y-0.5"
            >
              Bring the first problem →
            </a>
          </div>
        )
      }
    </div>
  </section>
</Base>
