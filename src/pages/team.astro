---
import Base from '../layouts/Base.astro';
import MakerCard from '../components/MakerCard.astro';
import { SITE } from '../lib/content';
import { getMakers } from '../lib/github';

const makers = await getMakers();
---

<Base title="Makers" description="The people building the MakerCommons — no gatekeeping, everyone who helps belongs.">
  <section class="pegboard border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 pb-16 pt-16 sm:pt-20">
      <p class="tag text-commons-deep">The makers</p>
      <h1 class="mt-3 font-display text-5xl font-extrabold tracking-tight sm:text-6xl">
        The makers
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">
        The people who show up and build. No degree, startup, or permission required —
        just a real problem or the will to help solve one.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-5 py-16">
      {
        makers.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {makers.map((m) => (
              <div class="reveal">
                <MakerCard maker={m} />
              </div>
            ))}
          </div>
        ) : (
          <div class="grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-20 text-center">
            <p class="font-display text-2xl font-bold">The roster is just starting.</p>
            <p class="mt-3 max-w-md text-ink-soft">
              Makers appear here once they join the GitHub org and make their
              membership public. Want to be one of the first?
            </p>
            <a
              href={SITE.contributing}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-5 py-2.5 font-semibold transition-transform hover:-translate-y-0.5"
            >
              How to join →
            </a>
          </div>
        )
      }
    </div>
  </section>
</Base>
