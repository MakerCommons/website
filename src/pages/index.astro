---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import MakerCard from '../components/MakerCard.astro';
import { SITE, STEPS, PRINCIPLES, STORY } from '../lib/content';
import { getProjects, getMakers } from '../lib/github';

const projects = await getProjects();
const makers = await getMakers();

const featured = projects.slice(0, 6);
const featuredMakers = makers.slice(0, 8);

const toolLine =
  projects.length === 0
    ? '0 tools shipped — bring the first problem'
    : `${projects.length} tool${projects.length > 1 ? 's' : ''} shipped`;
const makerLine =
  makers.length === 0 ? 'open to new makers' : `${makers.length} maker${makers.length > 1 ? 's' : ''}`;
---

<Base>
  <!-- ============================ HERO ============================ -->
  <section class="pegboard-strong relative overflow-hidden border-b-2 border-ink">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-full bg-gradient-to-b from-paper/40 via-paper/70 to-paper"
    >
    </div>
    <div class="mx-auto max-w-6xl px-5 pb-20 pt-20 sm:pt-28">
      <p class="tag inline-flex items-center gap-2 rounded-full border-2 border-ink bg-paper px-3 py-1">
        <span class="h-2 w-2 rounded-full bg-commons"></span>
        A makers’ collective · est. {SITE.est}
      </p>

      <h1
        class="mt-7 max-w-4xl font-display text-5xl font-extrabold leading-[0.98] tracking-tight sm:text-7xl"
      >
        Small tools.<br />Real problems.<br />
        Given away <span class="riso" data-text="free">free</span>.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft sm:text-xl">
        {SITE.name} is a collective of makers using modern tools — including AI — to
        solve the everyday problems ordinary people actually have, and release every
        solution open source. No paywalls. No rent. Just useful things, kept useful.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href={SITE.newIssue}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-ink px-6 py-3 font-semibold text-paper transition-transform hover:-translate-y-0.5"
        >
          Bring a problem →
        </a>
        <a
          href={SITE.manifesto}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-6 py-3 font-semibold text-ink transition-transform hover:-translate-y-0.5"
        >
          Read the manifesto
        </a>
      </div>

      <!-- Honest status ledger, in the shop-label voice -->
      <dl
        class="mt-12 flex flex-wrap gap-x-8 gap-y-3 border-t-2 border-ink pt-5 font-mono text-sm"
      >
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">status</dt>
          <dd class="font-medium">commons founded</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">tools</dt>
          <dd class="font-medium">{toolLine}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">makers</dt>
          <dd class="font-medium">{makerLine}</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="tag text-ink-soft">license</dt>
          <dd class="font-medium">{SITE.license}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ STORY ============================ -->
  <section class="border-b-2 border-ink">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-20 md:grid-cols-[0.8fr_1.2fr]">
      <div class="reveal">
        <p class="tag text-commons-deep">{STORY.eyebrow}</p>
        <p class="mt-4 font-display text-2xl font-bold leading-tight sm:text-3xl">
          Be greedy for the craft,<br class="hidden sm:block" /> not the invoice.
        </p>
      </div>
      <div class="reveal space-y-5 text-lg leading-relaxed text-ink-soft">
        {STORY.paragraphs.map((p) => <p>{p}</p>)}
        <p class="tag pt-2 text-ink">{STORY.signoff}</p>
      </div>
    </div>
  </section>

  <!-- ========================= HOW IT WORKS ======================= -->
  <section id="how" class="border-b-2 border-ink bg-paper-2">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="max-w-2xl">
        <p class="tag text-commons-deep">The loop</p>
        <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
          How the commons works
        </h2>
        <p class="mt-4 text-lg text-ink-soft">
          One repeatable loop, run in the open. That’s the whole thing.
        </p>
      </header>

      <ol class="mt-12 grid gap-px overflow-hidden rounded-xl border-2 border-ink bg-ink sm:grid-cols-2 lg:grid-cols-5">
        {
          STEPS.map((s) => (
            <li class="reveal flex flex-col bg-paper p-6">
              <span class="font-mono text-sm font-medium text-commons-deep">{s.n}</span>
              <h3 class="mt-3 font-display text-lg font-bold leading-tight">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ========================== PROJECTS ========================== -->
  <section id="projects" class="pegboard border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="tag text-commons-deep">The board</p>
          <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
            Tools on the pegboard
          </h2>
          <p class="mt-4 text-lg text-ink-soft">
            Every tool the collective has hung up — free, open, and built for a real problem.
          </p>
        </div>
        {
          projects.length > 6 && (
            <a
              href="/projects"
              class="rounded-lg border-2 border-ink bg-paper px-4 py-2 text-sm font-semibold transition-transform hover:-translate-y-0.5"
            >
              All {projects.length} projects →
            </a>
          )
        }
      </header>

      {
        featured.length > 0 ? (
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((p) => (
              <div class="reveal">
                <ProjectCard project={p} />
              </div>
            ))}
          </div>
        ) : (
          <div class="reveal mt-12 grid place-items-center rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-16 text-center">
            <p class="font-display text-2xl font-bold">The board is empty — for now.</p>
            <p class="mt-3 max-w-md text-ink-soft">
              Empty pegs are just problems waiting for a tool. Bring the first one and
              we’ll build the first solution, in the open, for free.
            </p>
            <a
              href={SITE.newIssue}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-5 py-2.5 font-semibold text-paper transition-transform hover:-translate-y-0.5"
            >
              Hang the first tool →
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ========================= PRINCIPLES ========================= -->
  <section class="border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="max-w-2xl">
        <p class="tag text-commons-deep">What we believe</p>
        <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
          Four non-negotiables
        </h2>
      </header>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {
          PRINCIPLES.map((p) => (
            <div class="reveal rounded-xl border-2 border-ink bg-paper p-7">
              <p class="tag text-ink-soft">{p.tag}</p>
              <h3 class="mt-2 font-display text-2xl font-bold leading-tight">{p.title}</h3>
              <p class="mt-3 leading-relaxed text-ink-soft">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================== MAKERS =========================== -->
  <section id="makers" class="border-b-2 border-ink bg-paper-2">
    <div class="mx-auto max-w-6xl px-5 py-20">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="tag text-commons-deep">The makers</p>
          <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
            People building the commons
          </h2>
          <p class="mt-4 text-lg text-ink-soft">
            No gatekeeping. Anyone who brings a problem or helps solve one belongs here.
          </p>
        </div>
        {
          makers.length > 8 && (
            <a
              href="/team"
              class="rounded-lg border-2 border-ink bg-paper px-4 py-2 text-sm font-semibold transition-transform hover:-translate-y-0.5"
            >
              All {makers.length} makers →
            </a>
          )
        }
      </header>

      {
        featuredMakers.length > 0 ? (
          <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {featuredMakers.map((m) => (
              <div class="reveal">
                <MakerCard maker={m} />
              </div>
            ))}
          </div>
        ) : (
          <div class="reveal mt-12 rounded-xl border-2 border-dashed border-ink/50 bg-paper/60 px-6 py-14 text-center">
            <p class="font-display text-2xl font-bold">Be one of the first.</p>
            <p class="mx-auto mt-3 max-w-md text-ink-soft">
              The collective is brand new. Bring a problem, build a tool, or help out —
              and your name goes on the board.
            </p>
            <a
              href={SITE.contributing}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-5 py-2.5 font-semibold transition-transform hover:-translate-y-0.5"
            >
              How to join →
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ============================ CTA ============================= -->
  <section class="pegboard-strong relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-paper/70"></div>
    <div class="mx-auto max-w-6xl px-5 py-24 text-center">
      <h2 class="mx-auto max-w-3xl font-display text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
        Got a small problem the world<br class="hidden sm:block" /> keeps overcharging you for?
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-soft">
        Tell us about it. If it’s real and shared, the commons will build the fix —
        free, open, and yours to keep.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <a
          href={SITE.newIssue}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-commons px-7 py-3.5 font-semibold text-paper transition-transform hover:-translate-y-0.5"
        >
          Bring a problem →
        </a>
        <a
          href={SITE.org}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-ink bg-paper px-7 py-3.5 font-semibold text-ink transition-transform hover:-translate-y-0.5"
        >
          Explore the org on GitHub
        </a>
      </div>
    </div>
  </section>
</Base>
